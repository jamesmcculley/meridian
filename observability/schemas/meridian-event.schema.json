{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meridian-labs.local/schemas/meridian-event.schema.json",
  "title": "MERIDIAN LABS Security Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "timestamp",
    "event_type",
    "source_zone",
    "destination_zone",
    "action",
    "service",
    "rationale",
    "environment"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "network_flow",
        "access_decision",
        "detection_finding",
        "incident_note"
      ]
    },
    "source_zone": {
      "type": "string",
      "minLength": 1
    },
    "destination_zone": {
      "type": "string",
      "minLength": 1
    },
    "source_service": {
      "type": "string"
    },
    "destination_service": {
      "type": "string"
    },
    "protocol": {
      "type": "string"
    },
    "port": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        {
          "type": "string",
          "enum": [
            "any",
            "management"
          ]
        }
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "observe",
        "alert"
      ]
    },
    "service": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "flow_id": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "informational",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "environment": {
      "type": "string",
      "enum": [
        "local",
        "ci",
        "planned"
      ]
    },
    "validation_status": {
      "type": "string",
      "enum": [
        "planned",
        "observed",
        "validated",
        "failed"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "integer",
          "boolean",
          "null"
        ]
      }
    }
  }
}
